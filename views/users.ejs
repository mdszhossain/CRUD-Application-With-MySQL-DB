<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Users</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <main class="users-page-shell">
        <section class="users-card">
            <div class="users-header">
                <div>
                    <h1 class="users-list">User Directory</h1>
                    <p class="users-subtitle">Manage account records in a clean and modern table layout.</p>
                </div>
                <a href="/newuser" class="create-user-btn">Create User</a>
            </div>

            <div class="table-container">
                <table class="users-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Edit</th>
                            <th>Destroy</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% for(let user of result) { %>
                            <tr>
                                <td><%= user.id %></td>
                                <td><%= user.username %></td>
                                <td><%= user.email %></td>
                                <td>
                                    <a href="/users/<%= user.id %>/update" id="edit-btn" class="user-btn secondary-btn">Edit</a>
                                </td>
                                <td>
                                    <form method="POST" action="http://localhost:8080/users/<%= user.id %>?_method=DELETE">
                                        <button id="delete-btn" class="user-btn danger-btn">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </section>
    </main>
</body>
</html>