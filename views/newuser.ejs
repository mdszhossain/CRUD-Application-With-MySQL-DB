<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Newuser</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <main class="page-shell">
        <section class="form-card">
            <h1 class="users-list">Create New User</h1>
            <p class="form-subtitle">Add a secure account with username, email, and password.</p>
            <form action="http://localhost:8080/users" method="POST" class="user-form">
                <div class="form-group">
                    <label for="username">Username</label>
                    <input type="text" id="username" name="username" placeholder="Enter username" required>
                </div>
                <div class="form-group">
                    <label for="email">Email</label>
                    <input type="email" id="email" name="email" placeholder="Enter email address" required>
                </div>
                <div class="form-group">
                    <label for="password">Password</label>
                    <input type="password" id="password" name="password" placeholder="Confirm password" required>
                </div>
                <button type="submit" class="submit-button">Submit</button>
            </form>
        </section>
    </main>
</body>
</html>